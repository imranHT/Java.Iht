//Develop a program that prints the multiplication table for a given number::

import java.util.Scanner;
public class Problems{
    public static void main(String[] args) {


        Scanner imran = new Scanner(System.in);

        System.out.println("Welcome to the Multiple calculator");
        System.out.println("Enter a Number here : ");
        int number = imran.nextInt();
        printMultiplicationNumber(number);

    }

   public static void printMultiplicationNumber(int number){

        int i = 1;
        while(i<=10){
            System.out.println(number + " X " + i + " = " + (number*i));

            i++;
        }
   }
}

//Create a program to sum all odd numbers form 1 to a specified number N;

import  java.util.Scanner;
public class Problems{
    public static void main(String[] args) {


        Scanner imran = new Scanner(System.in);

        System.out.println("Welcome to the oddsum calculator");
        System.out.println("Enter a number here : ");
        int num = imran.nextInt();
        int sum  = oddSum(num);
        System.out.println("Odd is " +num+ " is " +sum);
    }

    public static int oddSum(int num) {
        int sum = 0;
        int i = 1;
        while (i <= num) {
            sum += i;
            i += 2;

        }
        return sum;
    }
}


//write a function that calculates the factorial of a given number;

import java.util.Scanner;
public class Problems{
    public static void main(String[] args) {


        Scanner imran = new Scanner(System.in);
        System.out.println("Factorial calculator");
        System.out.println("Enter a number : ");
        int num = imran.nextInt();
        long fact = factorial(num);
        System.out.println("Factorial is " +fact);
    }

    public static long factorial(int num){

        if(num < 2){
            return 1;

        }
        long fact = 1;
        int i = 2;
        while(i <= num){
            fact *= i;
            i++;
        }
        return fact;
    }
}
