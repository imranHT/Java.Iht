//Create a program to sum all odd numbers form 1 to a specified number N;

import  java.util.Scanner;
public class Problems{
    public static void main(String[] args) {


        Scanner imran = new Scanner(System.in);

        System.out.println("Welcome to the oddsum calculator");
        System.out.println("Enter a number here : ");
        int num = imran.nextInt();
        int sum  = oddSum(num);
        System.out.println("Odd is " +num+ " is " +sum);
    }

    public static int oddSum(int num) {
        int sum = 0;
        int i = 1;
        while (i <= num) {
            sum += i;
            i += 2;

        }
        return sum;
    }
}


//write a function that calculates the factorial of a given number;

import java.util.Scanner;
public class Problems{
    public static void main(String[] args) {


        Scanner imran = new Scanner(System.in);
        System.out.println("Factorial calculator");
        System.out.println("Enter a number : ");
        int num = imran.nextInt();
        long fact = factorial(num);
        System.out.println("Factorial is " +fact);
    }

    public static long factorial(int num){

        if(num < 2){
            return 1;

        }
        long fact = 1;
        int i = 2;
        while(i <= num){
            fact *= i;
            i++;
        }
        return fact;
    }
}

//Create a problem that computes the sum of the digits of an integer;

import java.util.Scanner;
class Problems{
    public static void main(String[] args) {

        Scanner imran = new Scanner(System.in);
        System.out.println("Welcome to Sum of digits calculator");
        System.out.println("Enter a Number : ");
        int num = imran.nextInt();
        int sum = sumOfDigits(num);
        System.out.println("The value is "+sum);

    }

    public static int sumOfDigits(int num){
        int sum = 0;
        while(num > 0){
            sum += num % 10;
            num /= 10;
        }
        return sum;
    }

}


//Create a program to find the Least Common Multiple (LCM) of two numbers


import java.util.Scanner;
public class Problems{
    public static void main(String[] args) {


        Scanner imran  = new Scanner(System.in);
        System.out.println("Least Common multiple calculator");
        System.out.println("Enter firstN  :");
        int first = imran.nextInt();
        System.out.println("Enter secondN  :");
        int second = imran.nextInt();

        int lcm = lcm(first,second);
        System.out.println("LCM value is "+lcm);
    }


    public static int lcm(int first,int second){
        int i = 1;
        while(true){
            int factor = first * i;
            if(factor % second == 0){
                return factor;
            }
            i++;
        }
    }

}


//Create a program to find the Greatest Common Divisir (GCD) of two integers;
import java.util.Scanner;


class Problems{
    public static void main(String[] args) {
        Scanner imran  = new Scanner(System.in);

        System.out.println("Welcome to GCD calculator");
        System.out.println("Enter a number : ");
        int first = imran.nextInt();
        System.out.println("Enter another number :");
        int second = imran.nextInt();
        int gcd = gcd(first,second);
        System.out.println("GCD number is "+gcd);

    }
    public static int gcd(int num1,int num2){
        int gcd = 0;
        int i = 2;
        int least = least(num1,num2);
        while(i <= least){
            if(num1 % i == 0 && num2 % i == 0){
                gcd  = i;
            }
            i++;
        }
        return gcd;
    }

    public static int least(int num1,int num2){
        if(num1 < num2){
            return num1;
        }
        else {
            return num2;
        }
    }
}

//Create a program to check whether a given number is prime
import java.util.Scanner;

class Problems{
    public static void main(String[] args) {
Scanner imran = new Scanner(System.in);

        System.out.println("Welcome to Prime Number checker");
        System.out.println("Enter a valid number : ");
        int num = imran.nextInt();

        boolean isPrime = isPrime(num);
        if(isPrime){
            System.out.println("Prime Number Man");
        }
        else{
            System.out.println("Not a Prime number . try another number vodai..");
        }

    }

    public static boolean isPrime(int num){
        int i = 2;
        while(i < num ){
            if(num % i == 0){
                return false;
            }
            i++;
        }
        return true;
    }
}
