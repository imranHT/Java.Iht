package Composition;

public class Company {

 String companyName;
   int openningYear;
   String location;
   String title;
   Employee employee;


   Company(String companyName,int openningYear,
   String location,String title,String type,String name,int joiningDate,double salary){

       this.companyName = companyName;
       this.openningYear = openningYear;
       this.location = location;
       this.title = title;
       this.employee = new Employee(type,name,joiningDate,salary);
}


  void Environment(){
    this.employee.feeling();
    System.out.println("The "+ this.companyName + " is One of the leading company in bangladesh");
  }
}
package Composition;

public class Employee {

      String type;
      String name;
      int joiningDate;
      double salary;


      Employee(String type,String name,int joiningDate,double salary){
        this.type = type;
        this.name = name;
        this.joiningDate = joiningDate;
        this.salary = salary;

      }

      void feeling(){
        System.out.println("I feel very honored to joining the post "+this.type+ " in this Company ");
      }

   }

