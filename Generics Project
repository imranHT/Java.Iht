package Generics;

public class WorkerDetails<N,A,B,L,J,S,C,K> {


    N name;
    A age;
    B birth;
    L location;
    J job;
    S salary;
    K live;
    C company;


    public WorkerDetails(N name,A age,B birth,L location,J job,
        S salary, K live,C company){

            this.name = name;
            this.age = age;
            this.birth = birth;
            this.location = location;
            this.job = job;
            this.salary = salary;
            this.live=live;
            this.company = company;
            
        }

        public N getName(){
            return this.name;
        }
        public A getAge(){
            return this.age;
        }
        public B getBirth(){
            return this.birth;
        }
        public L getLocation(){
            return this.location;
        }
        public J getJob(){
            return this.job;
        }
        public S getSalary(){
            return this.salary;

        }
        public K getLive(){
            return this.live;
        }
        public C getCompany(){
            return this.company;
        }
       


}


