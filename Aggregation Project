package Aggregation;

public class Book {

   String title;
   int page;
   String writer;


   Book (String title, int page,String writer){
    this.title = title;
    this.page = page;
    this.writer = writer;
   }

   String displayInfo(){
   return this.title + " " + this.writer+ "  ("+ this.page+ " pages)";
   }
    
}

}

package Aggregation;

public class Library {

  String libraryName;
  int year;
  String location;
int totalBooks;
  
 Book[] books;

  Library(String libraryName,int year,String location,Book[] books,int totalBooks){
    this.libraryName = libraryName;
    this.year = year;
    this.location =  location;
    this.totalBooks = totalBooks;
   
    this.books = books;
  }


  void displayInfo(){

    System.out.println("The "+this.libraryName+ "  "+this.year+ "  "+ this.location+ " . Total Books : "+this.totalBooks);
System.out.println("\n");
    System.out.println("Books Available::");
    System.out.println("\n");
    for(Book book : books){
        System.out.println(book.displayInfo());
    }
  }

    
}

