import java.util.Scanner;

public class Bro9{
    public static void main(String[] args) {
        
        Scanner imran = new Scanner(System.in);

        String phone;
        String simCode;

        System.out.println("Enter Your Phone Number::");

        phone = imran.nextLine();

        if(phone.length() >= 4){
            simCode = phone.substring(0, 4);
            System.out.println("SimCode is +880 : "+simCode);
        }

        else{
            System.out.println("Invalid simCode");
        }

        imran.close();
    }
}

