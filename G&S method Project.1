package Gettersetter;

public class Car{
    
   private String carModel;
  private String transmissionType;
   private int engineHp;
  private int engineCode;
  private String CarDesigner;
  private String engineManufacturer;
  double price;


  Car(String carModel,String transmissionType,int engineHp,int engineCode,String CarDesiner,String engineManufacturer,double price){

   this.carModel = carModel;
   this.transmissionType = transmissionType;
   this.engineHp = engineHp;
   this.engineCode = engineCode;
   this.CarDesigner = CarDesiner;
   this.engineManufacturer = engineManufacturer;
   this.price = price;
  }

  String getCarModel(){
   return this.carModel;
  }
String getTransmissionType(){
   return this.transmissionType;
}
int getEngineHp(){
   return this.engineHp;
}
int getEngineCode(){
   return this.engineCode;
}

String getCarDesigner(){
   return this.CarDesigner;
}
String getEngineManufacturer(){
   return this.engineManufacturer;

}
double getPrice(){
   return this.price;
}

void  setCarModel(String carModel){
    this.carModel = carModel;
}
void setEngineHp(int engineHp){
   this.engineHp = engineHp;
}
void setEngineCode(int engineCode){
   this.engineCode = engineCode;
}  
void setPrice(double price){
   this.price = price;
}

 
}

