package Generics;

public class Pot<R,U> {

    R resourse;
    U price;


    public Pot(R resourse, U price){
        this.resourse = resourse;
        this.price = price;
    }


    public R getItem(){
        return this.resourse;
    }
   public U getPrice()
    {
    return this.price;
    }
 
    

}

