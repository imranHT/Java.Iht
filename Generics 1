package Generics;

public class Bio<N,Y,L> {

    N name;
    Y year;
    L location;


    public Bio( N name, Y year, L location){
        this.name = name;
        this.year = year;
        this.location = location;
    }

    public N getName(){
        return this.name;
    }
    public Y getYear(){
        return this.year;
    }
    public L getLocation(){
        return this.location;
    }

}
