 Bio<String,Integer,String> bio = new Bio<String,Integer,String>
 ("Imran Hasan", 24, "Sirajgong");


 System.out.println(bio.getName());
 System.out.println(bio.getYear());
 System.out.println(bio.getLocation());
    }
    
