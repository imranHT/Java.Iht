import java.util.Scanner;

public class Bro16{
    public static void main(String[] args)  throws InterruptedException {

        Scanner imran = new Scanner(System.in);

        System.out.println("Enter Countdown Number : ");  // enter any int number (1-10)

        int start = imran . nextInt();

        for(int i = start ; i>0 ; i--){    //Loop For Limit
                 System.out.println(i);
                 Thread.sleep(1000); //Thread Run 
         
        }

        System.out.println("Hello I am Imran .. I like Programming");


        imran.close(); //Close The Scanner
        

    }
}

