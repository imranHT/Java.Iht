package Composition;

public class Car {

  String model;
  int year;
  Engine engine;
    

  Car(String model,int year,String engineType){
    this.model = model;
    this.year = year;
    this.engine = new Engine(engineType);
  }

  void start(){
    this.engine.start();
    System.out.println("The "+this.model+" is running");
  }
}
package Composition;

public class Engine {

    String type;

    Engine (String type){
        this.type = type;
    }

    void start(){
        System.out.println("You start the "+this.type+ " engine");
    }
    
}

