package Enum;

public enum Staff {

   
  IMRAN(1),RAKIBUL(2),SAJU(3),SIFAT(4),NAHID(5),RIMEL(6),MILON(7),
  MAHFUZ(8),KAWSAR(9),SANTO(10);

  private final int staff;
  

  Staff(int staff){
    this.staff = staff;
  }
    public int getStaff(){
      return this.staff;
    }
}
