package Enum;

import java.util.Scanner;

public class Bro48 {
    
public static void main(String[] args) {
        
           Scanner imran = new Scanner(System.in);
           System.out.println("Enter a name from all Staff");
           String response = imran.nextLine().toUpperCase();



           try{

            Staff staff = Staff.valueOf(response);

            switch(staff){
                case IMRAN,NAHID,RIMEL,MILON -> System.out.println("Software Engineer ");

                case RAKIBUL,SAJU,SIFAT -> System.out.println("Civil Engineer");

                case MAHFUZ,KAWSAR -> System.out.println("Teacher");

                case SANTO -> System.out.println("Nobelist");
            }
           }
           catch(IllegalArgumentException e){
            System.out.println("Please enter valid name ");
           }

           imran.close();
    }
}

