package Gettersetter;

public class Add{
    
 private String name;
 private String title;
 private int age;
 private String location;


 Add(String name,String title,int age,String location){
    this.name = name;
    this.title = title;
    this.age = age;
    this.location = location;
 }

 String getName(){
    return this.name;

 }
 String getTitle(){
    return this.title;
 }
 int getAge(){
    return this.age;
 }

 String getLocation(){
    return this.location;
 }

 void setName(String name){
    this.name = name;
 }
 void setAge(int age){
    this.age = age;
 }

 void setTitle(String title){
    this.title = title;
 }
 
}


